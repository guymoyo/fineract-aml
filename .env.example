# ── Application ────────────────────────────────────────────
AML_APP_NAME=Fineract AML Service
AML_DEBUG=true

# ── Database ──────────────────────────────────────────────
AML_DATABASE_URL=postgresql+asyncpg://aml:aml@localhost:5433/fineract_aml

# ── Redis ─────────────────────────────────────────────────
AML_REDIS_URL=redis://localhost:6380/0
AML_CELERY_BROKER_URL=redis://localhost:6380/1
AML_CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── Fineract ──────────────────────────────────────────────
AML_FINERACT_BASE_URL=https://localhost:8443/fineract-provider/api/v1
AML_FINERACT_WEBHOOK_SECRET=change-me-in-production

# ── Auth ──────────────────────────────────────────────────
AML_SECRET_KEY=change-me-in-production
AML_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── ML ────────────────────────────────────────────────────
AML_MODEL_PATH=./models
AML_ANOMALY_THRESHOLD=0.7
AML_RISK_SCORE_HIGH=0.8
AML_RISK_SCORE_MEDIUM=0.5

# ── MLflow ────────────────────────────────────────────────
AML_MLFLOW_TRACKING_URI=http://localhost:5000
AML_MLFLOW_EXPERIMENT_NAME=fineract-aml

# ── Rule Engine ───────────────────────────────────────────
AML_MAX_TRANSACTION_AMOUNT=10000.0
AML_RAPID_TRANSACTION_WINDOW_MINUTES=60
AML_RAPID_TRANSACTION_COUNT=10
AML_STRUCTURING_THRESHOLD=9500.0
AML_NEW_ACCOUNT_AGE_DAYS=30
