# ============================================================
# Fineract AML Service — Environment Variables
# Copy to .env and fill in values for your environment.
# All variables are prefixed with AML_ at runtime.
# ============================================================

# ── Application ──────────────────────────────────────────────
AML_APP_NAME="Fineract AML Service"
AML_APP_VERSION="0.1.0"
AML_DEBUG=false
AML_API_PREFIX="/api/v1"

# ── Database (PostgreSQL + asyncpg) ──────────────────────────
AML_DATABASE_URL="postgresql+asyncpg://aml:aml@localhost:5432/fineract_aml"
AML_DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────
AML_REDIS_URL="redis://localhost:6379/0"

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
AML_CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ── Fineract integration ──────────────────────────────────────
AML_FINERACT_BASE_URL="https://localhost:8443/fineract-provider/api/v1"
# HMAC-SHA256 secret shared with the Fineract BFF for webhook signature validation
AML_FINERACT_WEBHOOK_SECRET="change-me-in-production"
# TLS verification for Fineract API calls. Set to false ONLY for local dev with self-signed certs.
# MUST be true in production to prevent MITM attacks.
FINERACT_TLS_VERIFY=false

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AML_SECRET_KEY="change-me-in-production"
AML_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Celery ────────────────────────────────────────────────────
AML_CELERY_BROKER_URL="redis://localhost:6379/1"
AML_CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ── ML models ─────────────────────────────────────────────────
# Directory where trained model files are stored (fraud_classifier.joblib, etc.)
AML_MODEL_PATH="./models"
AML_ANOMALY_THRESHOLD=0.7
AML_ANOMALY_CONTAMINATION=0.01

# ── MLflow (optional experiment tracking) ────────────────────
AML_MLFLOW_TRACKING_URI="http://localhost:5000"
AML_MLFLOW_EXPERIMENT_NAME="fineract-aml"

# ── Currency ──────────────────────────────────────────────────
AML_DEFAULT_CURRENCY="XAF"

# ── AML Rule engine thresholds ────────────────────────────────
AML_MAX_TRANSACTION_AMOUNT=10000.0
AML_RAPID_TRANSACTION_WINDOW_MINUTES=60
AML_RAPID_TRANSACTION_COUNT=10
# Structuring detection: amounts between structuring_threshold and max_transaction_amount
AML_STRUCTURING_THRESHOLD=9500.0
AML_NEW_ACCOUNT_AGE_DAYS=30

# ── CTR (Currency Transaction Report — CEMAC/COBAC) ──────────
# Transactions above this amount auto-generate a CTR (in XAF)
AML_CTR_THRESHOLD=5000000.0

# ── Sanctions screening ───────────────────────────────────────
AML_SANCTIONS_SCREENING_ENABLED=true
AML_SANCTIONS_MATCH_THRESHOLD=0.85

# ── Agent network fraud rules ─────────────────────────────────
AML_AGENT_STRUCTURING_MIN_COUNT=5
AML_AGENT_COLLUSION_WINDOW_MINUTES=60
AML_AGENT_FLOAT_IMBALANCE_THRESHOLD=0.95
AML_AGENT_FLOAT_VOLUME_MINIMUM=50000.0
AML_AGENT_NEW_ACCOUNT_THRESHOLD=8

# ── Network typology rules (IBM AMLSim) ──────────────────────
AML_SCATTER_GATHER_MIN_SENDERS=8
AML_BIPARTITE_FAN_THRESHOLD=5
AML_STACKING_WINDOW_MINUTES=30
AML_STACKING_AMOUNT_RATIO_MIN=0.8
AML_STACKING_AMOUNT_RATIO_MAX=1.2

# ── Merchant fraud rules ──────────────────────────────────────
AML_ANONYMOUS_PAYMENT_ALERT_THRESHOLD=100000.0

# ── Post-disbursement loan monitoring ─────────────────────────
AML_LOAN_RUN_THRESHOLD=0.8
AML_LOAN_IMMEDIATE_CASHOUT_MINUTES=30
AML_LOAN_DISPERSAL_COUNTERPARTY_MIN=5

# ── Credit scoring ─────────────────────────────────────────────
AML_CREDIT_TIER_A_MIN_SCORE=0.8
AML_CREDIT_TIER_B_MIN_SCORE=0.65
AML_CREDIT_TIER_C_MIN_SCORE=0.5
AML_CREDIT_TIER_D_MIN_SCORE=0.35
AML_CREDIT_TIER_A_MAX_AMOUNT=50000.0
AML_CREDIT_TIER_B_MAX_AMOUNT=20000.0
AML_CREDIT_TIER_C_MAX_AMOUNT=10000.0
AML_CREDIT_TIER_D_MAX_AMOUNT=1000.0
AML_CREDIT_MIN_TRANSACTIONS=5
AML_CREDIT_GAMING_INFLOW_MULTIPLIER=3.0
AML_CREDIT_GAMING_SCORE_PENALTY=0.15

# ── Adverse media screening (Phase 5.3) ──────────────────────
# Disabled by default — requires a NewsAPI key
AML_ADVERSE_MEDIA_ENABLED=false
AML_ADVERSE_MEDIA_API_KEY=""
AML_ADVERSE_MEDIA_API_URL="https://newsapi.org/v2/everything"
# Only screen counterparties on transactions with risk_score >= this threshold
AML_ADVERSE_MEDIA_MIN_RISK_SCORE=0.6

# ── LLM / AI Agent (Phase 6) ─────────────────────────────────
# Disabled by default — requires Anthropic API key
AML_LLM_INVESTIGATION_ENABLED=false
AML_ANTHROPIC_API_KEY=""
AML_LLM_MODEL="claude-opus-4-6"
# Minimum risk level to trigger LLM investigation: medium | high | critical
AML_LLM_INVESTIGATION_MIN_RISK_LEVEL="high"

# ── Synchronous scoring endpoint (Phase 7.5) ─────────────────
AML_SYNC_SCORING_ENABLED=true
# Max milliseconds before falling back to rules-only (degraded mode)
AML_SYNC_SCORING_TIMEOUT_MS=400

# ── Shadow/canary ML deployment (Phase 7.3) ──────────────────
# Enable to score every transaction with both production and shadow models
AML_SHADOW_MODEL_ENABLED=false
AML_SHADOW_MODEL_PROMOTION_AUC_DELTA=0.02
AML_SHADOW_MODEL_PROMOTION_DAYS=7

# ── Anomaly detector ensemble (Phase 7.2) ────────────────────
# Enable to combine IsolationForest (0.6×) + One-Class SVM (0.4×)
AML_ANOMALY_ENSEMBLE_ENABLED=false

# ── Risk score levels ─────────────────────────────────────────
AML_RISK_SCORE_HIGH=0.8
AML_RISK_SCORE_MEDIUM=0.5

# ── Graph visualization cache ─────────────────────────────────
AML_GRAPH_CACHE_TTL_SECONDS=1800
AML_GRAPH_REFRESH_INTERVAL_MINUTES=15
AML_GRAPH_LOOKBACK_HOURS=48
